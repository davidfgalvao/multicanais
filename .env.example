# Playlist primária iptv-org (predefinido: countries/br.m3u)
# IPTV_PLAYLIST_URL=https://iptv-org.github.io/iptv/index.m3u

# Segunda lista: categoria Sports do iptv-org (predefinido: categories/sports.m3u)
# Desativar só desporto: SKIP_SPORTS_PLAYLIST=1 ou SPORTS_PLAYLIST_URL=0
# SPORTS_PLAYLIST_URL=https://iptv-org.github.io/iptv/categories/sports.m3u

# Saltar download no build
# SKIP_IPTV_FETCH=1

# Lista local manual: npm run import:channels (ver /guia)
