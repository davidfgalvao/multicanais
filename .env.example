# Playlist primária iptv-org (predefinido: countries/br.m3u)
# IPTV_PLAYLIST_URL=https://iptv-org.github.io/iptv/index.m3u

# Listas extra do repositório github.com/iprtl/m3u (ramo live por defeito)
# Desativar: SKIP_IPRTL_M3U=1 ou IPRTL_M3U=0
# Outro ramo/commit: IPRTL_M3U_REF=main

# Manter canais com bandeira estrangeira ou palavras de outros países no grupo/nome (predefinido: remove)
# KEEP_FOREIGN_FLAG_CHANNELS=1

# Saltar download no build
# SKIP_IPTV_FETCH=1

# Não descarregar logos.json / channels.json do iptv-org (build/import mais rápido, logos só do M3U)
# SKIP_LOGO_ENRICH=1

# Lista local manual: npm run import:channels (ver /guia)

# Canais Premiere manuais (opcional): cole URLs oficiais em .env.local
# PREMIERE_CLUBES_URL=
# PREMIERE_2_URL=
# PREMIERE_3_URL=
# PREMIERE_4_URL=
# PREMIERE_5_URL=
# PREMIERE_6_URL=
# PREMIERE_7_URL=
# PREMIERE_8_URL=
# PREMIERE_LOGO_URL=https://i.imgur.com/xmmiHls.png

# URL pública (opcional): melhora Open Graph / partilhas sociais com a logo
# NEXT_PUBLIC_SITE_URL=https://teu-dominio.vercel.app
