# Playlist iptv-org no build (Vercel → Environment Variables)
# Predefinido: países/br.m3u (~200 canais). Lista mundial completa (~12k) aumenta tempo e tamanho do deploy.
# IPTV_PLAYLIST_URL=https://iptv-org.github.io/iptv/index.m3u

# Saltar download no build (usa o channels.generated.json já no disco)
# SKIP_IPTV_FETCH=1

# Lista local manual: npm run import:channels (ver /guia)
