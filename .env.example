# Playlist primária iptv-org no build (predefinido: countries/br.m3u)
# IPTV_PLAYLIST_URL=https://iptv-org.github.io/iptv/index.m3u

# Lista extra fundida à primária (predefinido: leandrosilvabr/iptv.lista-esporte iptvlista.m3u)
# Desativar segunda lista: EXTRA_PLAYLIST_URL=0
# EXTRA_PLAYLIST_URL=https://raw.githubusercontent.com/leandrosilvabr/iptv.lista-esporte/main/iptvlista.m3u

# Saltar todo o download no build
# SKIP_IPTV_FETCH=1

# Lista local manual: npm run import:channels (ver /guia)
